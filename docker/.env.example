# lxmd Propagation Node Configuration
# Copy to .env and edit as needed

# Node display name (included in announces)
LXMD_NODE_NAME=Rust Propagation Node

# Announce interval in minutes (default: 360 = 6 hours)
LXMD_ANNOUNCE_INTERVAL=360

# Message storage limit in megabytes (default: 500)
LXMD_STORAGE_LIMIT_MB=500

# Host port to expose Reticulum on (default: 37428)
LXMD_PORT=37428

# Maximum egress bandwidth — uses Linux tc (traffic control).
# Any tc-compatible rate string: 10mbit, 1mbit, 500kbit, etc.
# Set to "0" or "none" to disable bandwidth limiting.
LXMD_BANDWIDTH_LIMIT=10mbit

# Comma-separated list of static peer destination hashes
# LXMD_STATIC_PEERS=e17f833c4ddf8890dd3a79a6fea8161d,5a2d0029b6e5ec87020abaea0d746da4
